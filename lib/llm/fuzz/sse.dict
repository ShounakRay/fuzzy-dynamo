# SSE field names
"data: "
"event: "
"id: "
"retry: "
": "

# SSE values
"[DONE]"
"error"
"message"
"update"

# Line terminators (raw hex)
"\x0a"
"\x0d\x0a"
"\x0a\x0a"
"\x0d\x0a\x0d\x0a"

