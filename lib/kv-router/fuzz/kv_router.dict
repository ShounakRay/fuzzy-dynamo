"method"
"new"
"mark_prefill"
"mark_free"
"tokens"
"block_mm_infos"
"events"
"shutdown"
"event_id"
"data"
"dp_rank"
"stored"
"removed"
"cleared"
"parent_hash"
"blocks"
"block_hash"
