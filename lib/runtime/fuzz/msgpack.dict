# MsgPack fixed map (5 entries = 0x85)
"\x85"

# MsgPack string format markers
"\xa0"
"\xd9"
"\xda"

# Field names as MsgPack fixstr
"\xacpublisher_id"
"\xa8sequence"
"\xacpublished_at"
"\xa5topic"
"\xa7payload"

# MsgPack integer format markers
"\xcc"
"\xcd"
"\xce"
"\xcf"

# MsgPack bin format markers
"\xc4"
"\xc5"

# Frame header: version=1, payload_len varies
"\x01\x00\x00\x00\x00"
"\x01\x00\x00\x00\x10"
"\x01\x00\x00\x01\x00"

# MsgPack nil/bool
"\xc0"
"\xc2"
"\xc3"
